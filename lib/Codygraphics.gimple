}


void printnum(int loc,int num){
short stelle0;
short stelle1;
short stelle2;
short stelle3;
short stelle4;
short stelle5;
short stelle6;
short stelle7;

stelle0 = num & 1;
_1 = loc + 7;
vid_place_character_to_screen(_1,stelle0);

stelle1 = num & 2;
stelle1 = stelle1 >> 1;
_1 = loc + 6;
vid_place_character_to_screen(_1,stelle1);

stelle2 = num & 4;
stelle2 = stelle2 >> 2;
_1 = loc + 5;
vid_place_character_to_screen(_1,stelle2);

stelle3 = num & 8;
stelle3 = stelle1 >> 3;
_1 = loc + 4;
vid_place_character_to_screen(_1,stelle3);

stelle4 = num & 16;
stelle4 = stelle4 >> 4;
_1 = loc + 3;
vid_place_character_to_screen(_1,stelle4);

stelle5 = num & 32;
stelle5 = stelle5 >> 5;
_1 = loc + 2;
vid_place_character_to_screen(_1,stelle5);

stelle6 = num & 64;
stelle6 = stelle6 >> 6;
_1 = loc + 1;
vid_place_character_to_screen(_1,stelle6);

stelle7 = num & 128;
stelle7 = stelle7 >> 7;
vid_place_character_to_screen(loc,stelle7);
}
